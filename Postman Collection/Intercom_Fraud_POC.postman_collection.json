{
  "info": {
    "name": "Intercom Fraud Detection POC",
    "description": "End-to-end test collection for the Intercom fraud detection POC. Tests contact creation, conversation creation, reply, and webhook simulation. Run in order: Step 1 → Step 2 → Step 3 → Step 4 → Step 5.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "FastAPI local server. Replace with your ngrok URL when testing webhooks."
    },
    {
      "key": "contact_id",
      "value": "",
      "description": "Auto-populated by Step 1 test script."
    },
    {
      "key": "conversation_id",
      "value": "",
      "description": "Auto-populated by Step 2 test script."
    }
  ],
  "item": [
    {
      "name": "Step 1 — Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Confirm the FastAPI server is running before executing any other requests."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Server is healthy', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response contains status healthy', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('healthy');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 2 — Create contact (fraud customer)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"user\",\n  \"external_id\": \"fraud-cust-001\",\n  \"email\": \"glen.test@fraudpoc.com\",\n  \"name\": \"Glen Saldanha\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/contacts/",
          "host": ["{{base_url}}"],
          "path": ["contacts", ""]
        },
        "description": "Creates a new Intercom contact representing the flagged customer. The contact_id returned is saved automatically to the collection variable for use in Step 3."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contact created successfully', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test('Response contains contact id', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.collectionVariables.set('contact_id', json.id);",
              "    console.log('contact_id saved:', json.id);",
              "});",
              "",
              "pm.test('Contact role is user', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.role).to.eql('user');",
              "});",
              "",
              "pm.test('Response time under 3s', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 2b — Get contact by email (verify)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/contacts/email/glen.test@fraudpoc.com",
          "host": ["{{base_url}}"],
          "path": ["contacts", "email", "glen.test@fraudpoc.com"]
        },
        "description": "Searches Intercom for the contact by email to verify it was created correctly. Also tests the search endpoint."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contact found by email', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Email matches', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.email).to.eql('glen.test@fraudpoc.com');",
              "});",
              "",
              "pm.test('Contact id matches saved variable', function () {",
              "    var json = pm.response.json();",
              "    var saved = pm.collectionVariables.get('contact_id');",
              "    pm.expect(json.id).to.eql(saved);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 2c — Duplicate contact (expect 409)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"role\": \"user\",\n  \"external_id\": \"fraud-cust-001\",\n  \"email\": \"glen.test@fraudpoc.com\",\n  \"name\": \"Glen Saldanha\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/contacts/",
          "host": ["{{base_url}}"],
          "path": ["contacts", ""]
        },
        "description": "Attempts to create the same contact again. Expects a 409 response confirming duplicate handling works correctly."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Duplicate returns 409 or duplicate message', function () {",
              "    var json = pm.response.json();",
              "    var isDuplicate = pm.response.code === 409 || json.status_code === 409;",
              "    pm.expect(isDuplicate).to.be.true;",
              "});",
              "",
              "pm.test('Response contains meaningful message', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include('already exists');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 3 — Start conversation (fraud case)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"from_user\": {\n    \"type\": \"user\",\n    \"id\": \"{{contact_id}}\"\n  },\n  \"body\": \"FRAUD ALERT: Suspicious transaction detected on account fraud-cust-001. Transaction amount: €4,850. Location: Lagos, Nigeria. Risk score: 0.94. Please review immediately.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/conversations/",
          "host": ["{{base_url}}"],
          "path": ["conversations", ""]
        },
        "description": "Opens a new Intercom conversation for the flagged customer. Uses the contact_id saved from Step 2. The conversation_id is saved automatically for use in Step 4."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Conversation created', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains conversation id', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('id');",
              "    pm.collectionVariables.set('conversation_id', json.id);",
              "    console.log('conversation_id saved:', json.id);",
              "});",
              "",
              "pm.test('Response contains created_at timestamp', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('created_at');",
              "    pm.expect(json.created_at).to.be.a('number');",
              "});",
              "",
              "pm.test('Response time under 5s', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 4 — Reply to conversation (analyst decision)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message_type\": \"comment\",\n  \"type\": \"user\",\n  \"intercom_user_id\": \"{{contact_id}}\",\n  \"body\": \"Case reviewed. Transaction confirmed as fraudulent. Account has been flagged and card blocked. Customer notified via email. Case ID: FRAUD-2026-001.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/conversations/{{conversation_id}}/reply",
          "host": ["{{base_url}}"],
          "path": ["conversations", "{{conversation_id}}", "reply"]
        },
        "description": "Posts an analyst decision reply to the open fraud conversation. Uses both contact_id and conversation_id saved from previous steps."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Reply posted successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is valid JSON', function () {",
              "    pm.response.to.be.json;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 5 — Simulate webhook (conversation closed)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Hub-Signature", "value": "sha1=test_signature_for_local_dev" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"notification_event\",\n  \"app_id\": \"your_app_id\",\n  \"data\": {\n    \"type\": \"notification_event_data\",\n    \"item\": {\n      \"type\": \"conversation\",\n      \"id\": \"{{conversation_id}}\",\n      \"state\": \"closed\",\n      \"read\": true\n    }\n  },\n  \"links\": {},\n  \"id\": \"notif_001\",\n  \"topic\": \"conversation.admin.closed\",\n  \"delivery_status\": \"pending\",\n  \"delivery_attempts\": 1,\n  \"delivered_at\": 0,\n  \"first_sent_at\": 1713890400,\n  \"created_at\": 1713890400,\n  \"self\": null\n}"
        },
        "url": {
          "raw": "{{base_url}}/conversations/webhook",
          "host": ["{{base_url}}"],
          "path": ["conversations", "webhook"]
        },
        "description": "Simulates Intercom firing a conversation.admin.closed webhook event to your endpoint. In production this fires automatically when an analyst closes the case in the Intercom inbox."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Webhook accepted with 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Webhook response confirms receipt', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include('received');",
              "});",
              "",
              "pm.test('Webhook response time under 2s', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 5b — Webhook HEAD verification",
      "request": {
        "method": "HEAD",
        "header": [],
        "url": {
          "raw": "{{base_url}}/conversations/webhook",
          "host": ["{{base_url}}"],
          "path": ["conversations", "webhook"]
        },
        "description": "Intercom sends a HEAD request to verify your webhook endpoint is reachable before registering it in the Developer Hub. This confirms your endpoint responds correctly."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('HEAD request returns 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Step 6 — Get contact by ID (final verify)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/contacts/{{contact_id}}",
          "host": ["{{base_url}}"],
          "path": ["contacts", "{{contact_id}}"]
        },
        "description": "Final verification — retrieves the contact by ID to confirm the full record is intact in Intercom after the end-to-end flow."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Contact retrieved successfully', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Contact id matches', function () {",
              "    var json = pm.response.json();",
              "    var saved = pm.collectionVariables.get('contact_id');",
              "    pm.expect(json.id).to.eql(saved);",
              "});",
              "",
              "pm.test('Contact name is correct', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.name).to.eql('Glen Saldanha');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }    
  ]
}
